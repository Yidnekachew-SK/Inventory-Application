<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/categoryStyles/index-styles.css">
    <title>Sport equipment store</title>
</head>
<body>
    <%- include('../partials/nav') %>
    <div class="mainSection">
        <form action="/create" method="get">
            <button type="submit" class="addCategoryButton">Add Category</button>
        </form>
        <div class="categoryCardContainer">
            <% categories.forEach((category) => { %>
                <div class="categoryCard">
                    <p><a href="/item/<%= category.category_id %>"><%= category.category_name %></a></p>
                    <div class="categoryLinks">
                        <form action="/<%= category.category_id %>/update" method="get" style="display:inline;">
                            <button type="submit">
                                Update
                            </button>
                        </form>

                        <form action="/<%= category.category_id %>/delete?_method=DELETE" method="POST" style="display:inline;">
                            <button type="submit" onclick="return confirm('Are you sure you want to delete the category?');">
                                Delete
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </div>
    </div>
    <%- include('../partials/footer')%>
</body>
</html>